// =====================================================================
// PRISMA SCHEMA — Chatbot Backend (Express, terpisah dari frontend)
// Sinkron 1:1 dengan schema_chatbot_mysql.sql yang sudah dibuat
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AuthProvider {
  google
  github
}

enum PersonaType {
  tentara
  polisi
  dokter
  guru
}

enum MessageSender {
  user
  bot
}

// ---------------------------------------------------------------------
// USER — akun user/admin hasil register & login
// ---------------------------------------------------------------------
model User {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  password       String?
  avatarUrl      String?      @map("avatar_url")
  role           UserRole     @default(user)
  defaultPersona PersonaType? @map("default_persona")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  conversations   Conversation[]
  personasCreated Persona[]      @relation("PersonaCreator")

  @@map("users")
}

// ---------------------------------------------------------------------
// ACCOUNT — detail login OAuth Google/GitHub per user
// ---------------------------------------------------------------------
model Account {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  accessToken       String?      @map("access_token") @db.Text
  refreshToken      String?      @map("refresh_token") @db.Text
  expiresAt         DateTime?    @map("expires_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ---------------------------------------------------------------------
// SESSION — sesi login aktif (mendukung fitur Logout)
// ---------------------------------------------------------------------
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ---------------------------------------------------------------------
// PERSONA — master data: Tentara, Polisi, Dokter, Guru
// ---------------------------------------------------------------------
model Persona {
  id            String      @id @default(uuid())
  type          PersonaType @unique
  displayName   String      @map("display_name")
  description   String?     @db.Text
  systemPrompt  String      @map("system_prompt") @db.Text
  avatarUrl     String?     @map("avatar_url")
  isActive      Boolean     @default(true) @map("is_active")
  createdById   String?     @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  createdBy     User?          @relation("PersonaCreator", fields: [createdById], references: [id])
  conversations Conversation[]

  @@map("personas")
}

// ---------------------------------------------------------------------
// CONVERSATION — percakapan user
// ---------------------------------------------------------------------
model Conversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  personaId String    @map("persona_id")
  title     String    @default("Percakapan Baru")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona  Persona   @relation(fields: [personaId], references: [id])
  messages Message[]

  @@map("conversations")
}

// ---------------------------------------------------------------------
// MESSAGE — isi chat, sender user/bot
// ---------------------------------------------------------------------
model Message {
  id             String        @id @default(uuid())
  conversationId String        @map("conversation_id")
  sender         MessageSender
  content        String        @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}
