# Server
PORT=5000
NODE_ENV=development

# Frontend URL (untuk CORS & redirect setelah OAuth login)
FRONTEND_URL="http://localhost:3000"

# Database (samain dengan MySQL yang sudah kamu setup)
DATABASE_URL="mysql://root:password@localhost:3306/db_chatbot"

# JWT
JWT_SECRET="ganti-dengan-random-string-panjang"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:5000/api/auth/github/callback"
